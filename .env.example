# Copiá este archivo como .env.local y completá los valores.
# .env.local NO se sube a GitHub (está en .gitignore).

# URL del proyecto de Supabase (local o nube)
VITE_SUPABASE_URL=

# Anon key de Supabase (local o nube)
VITE_SUPABASE_ANON_KEY=

